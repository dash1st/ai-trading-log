# 한국투자증권 KIS API 키 설정 가이드
# 1. 아래 항목들의 "여기에_입력" 부분을 실제 부여받은 키로 변경하세요.
# 2. 이 파일의 이름을 `.env` 로 변경하세요. (.env.example -> .env)

# KIS_DOMAIN 옵션: 
# 실전투자: https://openapi.koreainvestment.com:9443
# 모의투자: https://openapivts.koreainvestment.com:29443
KIS_DOMAIN=https://openapivts.koreainvestment.com:29443

KIS_APP_KEY=여기에_App_Key_입력
KIS_APP_SECRET=여기에_App_Secret_입력
KIS_ACCOUNT_NO=여기에_계좌번호_입력 (예: 12345678-01)
