{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":[" "],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83d\udcca AI \ud2b8\ub808\uc774\ub529 \ubd07 \ub300\uc2dc\ubcf4\ub4dc \uba54\uc778","text":"<p>\ud658\uc601\ud569\ub2c8\ub2e4! \uc774 \uacf3\uc740 AI \ud2b8\ub808\uc774\ub529 \ubd07\uc774 24\uc2dc\uac04 \ubc31\uadf8\ub77c\uc6b4\ub4dc\ub85c \ub3cc\uc544\uac00\uba70 \uc0dd\uc131\ud558\ub294 \ubaa8\uc758\ud22c\uc790 \uc77c\uc9c0, \ubcf4\uace0\uc11c, \uc804\ub7b5 \uc544\uce74\uc774\ube0c \uacf5\uac04\uc785\ub2c8\ub2e4.</p> <p>\ubd07\uc774 \uc790\ub3d9\uc73c\ub85c <code>docs/</code> \ud3f4\ub354 \ud558\uc704\uc5d0 \ub9c8\ud06c\ub2e4\uc6b4(<code>.md</code>) \ud30c\uc77c\uc744 \uc791\uc131\ud558\uba74, \uc774 \uc6f9\ud398\uc774\uc9c0\uc5d0 \uc2e4\uc2dc\uac04\uc73c\ub85c \ubc18\uc601\ub429\ub2c8\ub2e4!</p>"},{"location":"#_1","title":"\ud83d\ude80 \ucd5c\uc2e0 \ud604\ud669","text":"<ul> <li>\ud604\uc7ac \uc0c1\ud0dc: \ubaa8\uc758\ud22c\uc790 \uc9c4\ud589 \uc911 \ud83d\udfe2</li> <li>\ub9c8\uc9c0\ub9c9 \uc5c5\ub370\uc774\ud2b8: \uc624\ub298</li> </ul> <p>\ud83d\udc48 \uc67c\ucabd \uba54\ub274\ud0d0\uc0c9\uae30\ub97c \ud1b5\ud574 \ubd07\uc774 \ub0a8\uae34 \ubc29\ub300\ud55c \uae30\ub85d\ub4e4\uc744 \ud655\uc778\ud574\ubcf4\uc138\uc694.</p>"},{"location":"logs/2026-02/","title":"\ud83d\udcc5 2026\ub144 2\uc6d4 \ub9e4\ub9e4 \uc77c\uc9c0","text":"\ub0a0\uc9dc \uc885\ubaa9\uba85 \ud3ec\uc9c0\uc158 \ub9e4\uc218\uac00 \ub9e4\ub3c4\uac00 \uc218\uc775\ub960 \ube44\uace0 02/28 \uc608\uc2dc\uc885\ubaa9 LONG 45,000 46,000 +2.2% FVG \uc9c4\uc785 \ud0c0\uc810 \uc801\uc911 02/28 \uc608\uc2dc\uc885\ubaa92 SHORT 120,000 119,000 +0.8% \uc804\uace0\uc810 \ub3cc\ud30c \uc2e4\ud328 \ud6c4 \uc800\ud56d <p>\ubd07\uc774 \uc790\ub3d9\uc73c\ub85c \uc774 \ud14c\uc774\ube14\uc744 \uc5c5\ub370\uc774\ud2b8\ud558\uac70\ub098, \ud558\ub8e8 \ub2e8\uc704 \ubd84\uc11d \ud398\uc774\uc9c0\ub97c \uc0c8\ub85c \uc0dd\uc131\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p>"},{"location":"strategy/casper_fvg/","title":"\uce90\uc2a4\ud37c (Casper) SMC FVG (Fair Value Gap) \ub9e4\ub9e4 \uc804\ub7b5","text":"<p>\uc774 \ubb38\uc11c\ub294 AI \ud2b8\ub808\uc774\ub529 \ubd07\uc774 \ud2b9\uc815 \uc2dc\uac04\ub300(\ub2e8\uae30 \ubaa8\uba58\ud140)\uc5d0 \uc720\ub3d9\uc131 \uac2d(FVG)\uc744 \ud65c\uc6a9\ud574 \ub9e4\ub9e4 \ud0c0\uc810\uc744 \uc7a1\ub294 \"\uce90\uc2a4\ud37c\uc758 90\ubd84 FVG \ub2e8\ud0c0 \uc804\ub7b5\"\uc744 \ubd84\uc11d\uae30\uc5d0 \uc801\uc6a9\ud558\uae30 \uc704\ud574 \uc815\ub9ac\ud55c \uae30\uc900 \ubb38\uc11c\uc785\ub2c8\ub2e4.</p>"},{"location":"strategy/casper_fvg/#_1","title":"\ud83d\udccc \ud575\uc2ec \ucca0\ud559","text":"<ul> <li>\uc9e7\uc740 \uc2dc\uac04, \ub192\uc740 \ud6a8\uc728: \ud558\ub8e8 \uc885\uc77c \ucc28\ud2b8\ub97c \ubcf4\uba70 \ub1cc\ub3d9\ub9e4\ub9e4\ub97c \ud558\ub294 \ub300\uc2e0, \uc720\ub3d9\uc131\uc774 \uac00\uc7a5 \ud48d\ubd80\ud55c \ud2b9\uc815 90\ubd84(\uc608: \ub274\uc695\uc7a5 \uc624\ud508 \uc9c1\ud6c4)\uc5d0\ub9cc \ub9e4\ub9e4\ud558\uc5ec \uc2b9\ub960\uc744 \uadf9\ub300\ud654\ud569\ub2c8\ub2e4.</li> <li>FVG (Fair Value Gap, \uacf5\uc815 \uac00\uce58 \uac2d): \uac00\uaca9\uc774 \uae09\ub4f1/\uae09\ub77d\ud558\uba70 \ub9e4\uc218\u00b7\ub9e4\ub3c4 \uac70\ub798\uac00 \uce58\uc5f4\ud558\uac8c \uc774\ub904\uc9c0\uc9c0 \ubabb\ud558\uace0 '\ube44\uc5b4\ubc84\ub9b0' \uce94\ub4e4 \uc0ac\uc774\uc758 \uacf5\uac04. \uc2dc\uc7a5\uc740 \uc774 \ubd88\uade0\ud615\uc744 \ucc44\uc6b0\uae30 \uc704\ud574 \uc2ed\uc911\ud314\uad6c \ud574\ub2f9 \uac00\uaca9\ub300\ub85c '\ub418\ub3cc\ub9bc(\ud68c\uadc0)' \ud604\uc0c1\uc744 \ubcf4\uc785\ub2c8\ub2e4.</li> <li>\uc544\ubb34 FVG\ub098 \ub4e4\uc5b4\uac00\uc9c0 \uc54a\ub294\ub2e4: \uc2dc\uac04, \uae30\uc900\uc120 \ub3cc\ud30c, FVG \ud615\uc131\uc774\ub77c\ub294 3\uac00\uc9c0 \ud544\uc218 \uc870\uac74\uc774 \ubaa8\ub450 \ucda9\uc871\ub41c \uacf3\uc5d0\uc11c\ub9cc \uc9c4\uc785\ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"strategy/casper_fvg/#fvg-fair-value-gap","title":"\ud83d\udd0d FVG (Fair Value Gap) \uc2dd\ubcc4 \ubc29\ubc95","text":"<p>\ucc28\ud2b8\uc0c1 \uc5f0\uc18d\ub41c 3\uac1c\uc758 \uce94\ub4e4\uc744 \ubd05\ub2c8\ub2e4. 1. \uc0c1\uc2b9 FVG (\ub871 \ud0c0\uc810): 1\ubc88 \uce94\ub4e4\uc758 \uace0\uac00\uc640 3\ubc88 \uce94\ub4e4\uc758 \uc800\uac00 \uc0ac\uc774\uc5d0 \uacb9\uce58\ub294 \uaf2c\ub9ac\uac00 \uc5c6\uc774 \ubee5 \ub6ab\ub9b0 \ube48 \uacf5\uac04 (2\ubc88 \uce94\ub4e4\uc758 \uac70\ub300\ud55c \uc591\ubd09 \ubab8\ud1b5 \uad6c\uac04). 2. \ud558\ub77d FVG (\uc20f \ud0c0\uc810): 1\ubc88 \uce94\ub4e4\uc758 \uc800\uac00\uc640 3\ubc88 \uce94\ub4e4\uc758 \uace0\uac00 \uc0ac\uc774\uc5d0 \uacb9\uce58\ub294 \uaf2c\ub9ac\uac00 \uc5c6\ub294 \ube48 \uacf5\uac04 (2\ubc88 \uce94\ub4e4\uc758 \uac70\ub300\ud55c \uc74c\ubd09 \ubab8\ud1b5 \uad6c\uac04).</p>"},{"location":"strategy/casper_fvg/#3","title":"\ud83d\udfe2 \ub871(\ub9e4\uc218) \ud3ec\uc9c0\uc158 \uc9c4\uc785 \uc804\ub7b5 (3\uac00\uc9c0 \ud544\uc218 \uc870\uac74)","text":""},{"location":"strategy/casper_fvg/#1","title":"1\ub2e8\uacc4: \uc720\ub3d9\uc131\uc774 \ubab0\ub9ac\ub294 '\ud2b9\uc815 \uc2dc\uac04' \uc9c0\uc815","text":"<ul> <li>24\uc2dc\uac04 \ub9e4\ub9e4\ub97c \uae08\uc9c0\ud569\ub2c8\ub2e4.</li> <li>KIS API(\ud55c\uad6d \uc8fc\uc2dd) \uc801\uc6a9 \uc2dc \uc624\uc804 9\uc2dc 00\ubd84 ~ 10\uc2dc 30\ubd84 (\uc7a5 \ucd08\ubc18 90\ubd84) \uac19\uc774 \ub9e4\uc218\uc138\uac00 \ud3ed\ubc1c\ud558\ub294 \uc2dc\uac04\ub300\ub85c \ud55c\uc815\ud569\ub2c8\ub2e4. (\ubbf8\uc7a5 \uae30\uc900\uc740 \ub274\uc695\uc7a5 \uc624\ud508\uc778 \ubc24 10\uc2dc 30\ubd84 \ub610\ub294 11\uc2dc 30\ubd84)</li> </ul>"},{"location":"strategy/casper_fvg/#2-155","title":"2\ub2e8\uacc4: \uc0c1\uc704 \ud0c0\uc784\ud504\ub808\uc784(15\ubd84/5\ubd84\ubd09) '\uae30\uc900\uc120' \ub4dc\ub85c\uc789","text":"<ul> <li>\ub9e4\ub9e4\ud560 \ud0c0\uc784\ud504\ub808\uc784\ubcf4\ub2e4 \ud55c \ub2e8\uacc4 \ub192\uc740 \uce94\ub4e4\uc744 \ubd05\ub2c8\ub2e4. (\uc608: 5\ubd84\ubd09 \ub2e8\ud0c0 \uc2dc 15\ubd84\ubd09 \ud655\uc778 / 1\ubd84\ubd09 \ub2e8\ud0c0 \uc2dc 5\ubd84\ubd09 \ud655\uc778)</li> <li>\uc2dc\uc791 \uc2dc\uac04\uc758 \uccab \ubc88\uc9f8 \uc0c1\uc704 \uce94\ub4e4(\uc608: 9\uc2dc \uc815\uac01\uc758 15\ubd84\ubd09 \uce94\ub4e4)\uc758 \uace0\uac00(High)\uc640 \uc800\uac00(Low)\uc5d0 \uac01\uac01 \uac00\ub85c \uae30\uc900\uc120\uc744 \uae0b\uc2b5\ub2c8\ub2e4.</li> </ul>"},{"location":"strategy/casper_fvg/#3-fvg","title":"3\ub2e8\uacc4: \uae30\uc900\uc120 \ub3cc\ud30c \ubc0f FVG \uc0dd\uc131 \ud655\uc778 (\ud0c0\uc810)","text":"<ul> <li>\uc774\uc81c \ud558\uc704 \ud0c0\uc784\ud504\ub808\uc784(\uc608: 5\ubd84\ubd09 \ub610\ub294 1\ubd84\ubd09) \ucc28\ud2b8\ub85c \ub0b4\ub824\uc635\ub2c8\ub2e4.</li> <li>\uc870\uac74: \uce94\ub4e4\uc774 2\ub2e8\uacc4\uc5d0\uc11c \uadf8\uc5b4\ub454 '\uace0\uac00 \uae30\uc900\uc120'\uc744 \ubab8\ud1b5\uc73c\ub85c \uac15\ub825\ud558\uac8c \uc0c1\ud5a5 \ub3cc\ud30c\ud558\uba74\uc11c, \uadf8 \uc790\ub9ac\uc5d0 \uc0c1\uc2b9 FVG\uac00 \ub9cc\ub4e4\uc5b4\uc9c0\ub294\uc9c0 \uad00\ucc30\ud569\ub2c8\ub2e4.</li> </ul>"},{"location":"strategy/casper_fvg/#_2","title":"\ud83d\udcb8 \ub9e4\ub9e4 \uc2e4\ud589 (\uc9c4\uc785/\uc190\uc808/\uc775\uc808)","text":"<ul> <li>\uc9c4\uc785 \ud0c0\uc810 (\ub418\ub3cc\ub9bc \ub9e4\uc218): \uc8fc\uac00\uac00 \uae09\ub4f1 \ud6c4 \uc7a0\uc2dc \ube60\uc9c0\uba74\uc11c, \uc55e\uc11c \ub9cc\ub4e4\uc5b4\uc9c4 'FVG \ube48 \uacf5\uac04' \uc548\uc73c\ub85c \uac00\uaca9\uc774 \ub2e4\uc2dc \uc9c4\uc785(\ub418\ub3cc\ub9bc)\ud560 \ub54c \uc9c0\uc815\uac00 \ub9e4\uc218\ub97c \ub4e4\uc5b4\uac11\ub2c8\ub2e4.</li> <li>\uc190\uc808\uac00 (Stop Loss): \ud574\ub2f9 FVG\ub97c \ub9cc\ub4e4\uc5b4\ub0b8 \uc9c1\uc804 \uce94\ub4e4\uc758 \uc800\uc810 \ubc11\uc73c\ub85c \uc774\ud0c8 \uc2dc \uc190\uc808.</li> <li>\uc775\uc808\uac00 (Take Profit): \uc190\uc775\ube44 1 : 2 \ub610\ub294 1 : 3 \uc73c\ub85c \uc138\ud305.</li> </ul>"},{"location":"strategy/casper_fvg/#_3","title":"\ud83d\udd34 \uc20f(\ub9e4\ub3c4) \ud3ec\uc9c0\uc158 \uc9c4\uc785 \uc804\ub7b5","text":"<p>\ub871 \uc804\ub7b5\uc744 \ubc18\ub300\ub85c \ub4a4\uc9d1\uc2b5\ub2c8\ub2e4. (\ud55c\uad6d \uc8fc\uc2dd \ud604\ubb3c\uc740 \uacf5\ub9e4\ub3c4\uac00 \uc5b4\ub824\uc6b0\ub098, \uc774 \uc2dc\uadf8\ub110\uc744 '\uae30\uc874 \uc8fc\uc2dd \uc804\ub7c9 \ub9e4\ub3c4 \ubc0f \uad00\ub9dd' \ud544\ud130\ub85c \uc0ac\uc6a9)</p> <ol> <li>\uc9c0\uc815 \uc2dc\uac04: \uc7a5 \ucd08\ubc18 90\ubd84</li> <li>\uae30\uc900\uc120: \uccab \uc0c1\uc704 \uce94\ub4e4(15\ubd84\ubd09)\uc758 \uc800\uac00(Low) \uc120\uc5d0 \uc8fc\ubaa9.</li> <li>\ub3cc\ud30c \ubc0f FVG: \ud558\uc704 \uce94\ub4e4\uc774 '\uc800\uac00 \uae30\uc900\uc120'\uc744 \uc74c\ubd09 \ubab8\ud1b5\uc73c\ub85c \uae68\uace0 \ud558\ub77d\ud558\uba70, \uadf8 \uc790\ub9ac\uc5d0 \ud558\ub77d FVG\uac00 \ubc1c\uc0dd.</li> <li>\uc9c4\uc785: \uc8fc\uac00\uac00 \uc0b4\uc9dd \ubc18\ub4f1\ud558\uc5ec \ud558\ub77d FVG \uacf5\uac04 \uc548\uc73c\ub85c \ub418\ub3cc\ub9bc\uc744 \uc904 \ub54c \uc20f(\ub9e4\ub3c4) \uc9c4\uc785.</li> <li>\uc190\uc808\uac00: FVG \uc0dd\uc131 \uce94\ub4e4 \uc9c1\uc804 \uace0\uc810 \ub3cc\ud30c \uc2dc \uc190\uc808 / \uc775\uc808\uac00: \uc190\uc775\ube44 1:2.</li> </ol>"},{"location":"strategy/casper_fvg/#ai-next-step","title":"\ud83e\udd16 AI \ubd07 \uc801\uc6a9 \ubc29\uc548 (Next Step &amp; \ud55c\uacc4\uc810)","text":"<p>\uc55e\uc73c\ub85c <code>quant_analyzer.py</code> \ubaa8\ub4c8 \ucabd\uc5d0 \uc774 SMC \ub85c\uc9c1\uc744 \ucd94\uac00\ud558\ub824\uba74 \ub2e4\uc74c\uc758 \uae30\ubc95\uc801 \uc124\uacc4\uac00 \ud544\uc694\ud569\ub2c8\ub2e4.</p> <ol> <li>\uc2dc\uac04 \uc81c\ud55c \ubaa8\ub4c8 (Time Window)</li> <li><code>ai_trading_bot.py</code>\ub8e8\ud504\uc5d0\uc11c \ud604\uc7ac \uc2dc\uac04\uc774 09:00 ~ 10:30 \uc0ac\uc774\uac00 \uc544\ub2d0 \uacbd\uc6b0, \"FVG \uc804\ub7b5 \ud734\uc2dd(\uad00\ub9dd)\" \ubaa8\ub4dc\ub85c \uc804\ud658\ud558\ub294 \ud0c0\uc784 \ub77d\ucee4(Time Locker) \uad6c\ud604.</li> <li>\uba40\ud2f0 \ud0c0\uc784\ud504\ub808\uc784 \ub370\uc774\ud130 \ud638\ucd9c</li> <li>KIS API\ub97c \ud1b5\ud574 \ub2e8\uc21c 1\uc77c\ubd09(Daily)\uc774 \uc544\ub2cc, 15\ubd84\ubd09\uacfc 5\ubd84\ubd09 \ub370\uc774\ud130\ub97c \ub3d9\uc2dc\uc5d0 \uac00\uc838\uc640\uc57c \ud569\ub2c8\ub2e4.</li> <li>\uccab 15\ubd84\ubd09\uc758 High/Low \uac12\uc744 \ubcc0\uc218\uc5d0 \uc800\uc7a5(<code>target_high</code>, <code>target_low</code>).</li> <li>\ubc30\uc5f4 3\uac1c\ub85c FVG \uac80\ucd9c \ub85c\uc9c1 \uc791\uc131</li> <li>\ud310\ub2e4\uc2a4 \ub370\uc774\ud130\ud504\ub808\uc784\uc5d0\uc11c \uc5f0\uc18d\ub41c \uc778\ub371\uc2a4 <code>i-2, i-1, i</code> \uce94\ub4e4\uc744 \uc77d\uc5b4\ub4e4\uc785\ub2c8\ub2e4.</li> <li>\ub871 \uac2d: <code>High[i-2] &lt; Low[i]</code>\uac00 True\uc778\uc9c0 \uac80\uc0ac\ud558\uc5ec \uac2d \ubc15\uc2a4\uc758 \uc0c1\ub2e8(<code>Low[i]</code>)\uacfc \ud558\ub2e8(<code>High[i-2]</code>) \uc88c\ud45c\ub97c \uae30\ub85d.</li> <li>\uc790\ub3d9 \ub418\ub3cc\ub9bc \uac10\uc9c0 \uc54c\ub9bc</li> <li>\ud604\uc7ac\uac00\uac00 \uae30\ub85d\ud574 \ub454 \uac2d \ubc15\uc2a4 \ubc94\uc704 \uc548\uc73c\ub85c \ub4e4\uc5b4\uc624\uba74 \ud154\ub808\uadf8\ub7a8 \ubd07\uc73c\ub85c \"\ud83d\udea8 [\uce90\uc2a4\ud37c \uc804\ub7b5] \uc885\ubaa9 X \uc0c1\uc2b9 FVG \ub418\ub3cc\ub9bc \ub3c4\ub2ec! \ub9e4\uc218 \ud0c0\uc810!\" \uc54c\ub9bc\uc744 \uc804\uc1a1.</li> </ol>"},{"location":"strategy/ross_cameron/","title":"\ub85c\uc2a4 \uce74\uba54\ub860 (Ross Cameron) 3\ub2e8\uacc4 \uadf9\ub2e8\uc801 \ubaa8\uba58\ud140 \ub9e4\ub9e4 \uc804\ub7b5","text":"<p>\uc774 \ubb38\uc11c\ub294 AI \ud2b8\ub808\uc774\ub529 \ubd07\uc774 \uc2dc\uc7a5 \ub370\uc774\ud130\ub97c \ubd84\uc11d\ud558\uace0 \ub9e4\ub9e4 \uc2dc\uadf8\ub110\uc744 \ud544\ud130\ub9c1\ud560 \ub54c \uae30\uc900\uc810\uc73c\ub85c \uc0bc\uae30 \uc704\ud55c \"\ub85c\uc2a4 \uce74\uba54\ub860\uc758 RSI + \ubcfc\ub9b0\uc800 \ubc34\ub4dc + MACD \uc870\ud569 \uc804\ub7b5\"\uc744 \uc815\ub9ac\ud55c \uac83\uc785\ub2c8\ub2e4.</p>"},{"location":"strategy/ross_cameron/#_1","title":"\ud83d\udccc \ud575\uc2ec \ucca0\ud559","text":"<ul> <li>RSI\ub294 \ubcf4\uc870 \ud544\ud130\uc77c \ubfd0 \uc808\ub300\uc801 \uc9c4\uc785 \uc2e0\ud638\uac00 \uc544\ub2c8\ub2e4. \ud604\uc7ac\uc758 \uc0c1\ub300\uc801 \uac15\ub3c4\ub97c \ud655\uc778\ud558\ub294 '\uacbd\uace0\ub4f1' \uc5ed\ud560\ub85c\ub9cc \uc4f4\ub2e4.</li> <li>RSI 50 \ubd80\uadfc \ud6a1\ubcf4\uc7a5\uc740 \ucca0\uc800\ud788 \ud53c\ud55c\ub2e4. \ubcc0\ub3d9\uc131\uc774 \uc5c6\uc5b4 \uae30\ud68c \ube44\uc6a9\uc774 \ubb36\uc774\uac70\ub098 \uc7a6\uc740 \uc190\uc808\uc774 \ubc1c\uc0dd\ud560 \ud655\ub960\uc774 \ub192\uae30 \ub54c\ubb38\uc774\ub2e4.</li> <li>\ub0a8\ub4e4\uc774 \ubb34\uc11c\uc6cc\ud558\ub294 RSI 30 \uc774\ud558(\uadf9\ub2e8\uc801 \uacfc\ub9e4\ub3c4)\uc640 70 \uc774\uc0c1(\uadf9\ub2e8\uc801 \uacfc\ub9e4\uc218) \uad6c\uac04\uc744 \"\uac15\ub825\ud55c \ubaa8\uba58\ud140\uc758 \uc2dc\uc791\"\uc73c\ub85c \ud574\uc11d\ud558\uc5ec \ucc0c\ub974\uae30(\uc9c4\uc785)\ub97c \ub178\ub9b0\ub2e4.</li> </ul>"},{"location":"strategy/ross_cameron/#3","title":"\ud83d\udfe2 \ub871(\ub9e4\uc218) \ud3ec\uc9c0\uc158 \uc9c4\uc785 \uc804\ub7b5 (3\ub2e8\uacc4 + \ucd5c\uc885 \uac80\uc99d)","text":""},{"location":"strategy/ross_cameron/#1-rsi","title":"1\ub2e8\uacc4: RSI \uc608\ube44 \uc2e0\ud638 \ud3ec\ucc29","text":"<ul> <li>\uc870\uac74: 14\uc77c RSI \uc218\uce58\uac00 30 \uc774\ud558(\uacfc\ub9e4\ub3c4)\ub85c \uace4\ub450\ubc15\uc9c8\uce58\ub294 \uc885\ubaa9 \ud0d0\uc0c9. (\uc9c1\uc804 \uc74c\ubd09\uc774 \uc5f0\ub2ec\uc544 \uc3df\uc544\uc9c0\ub294 \ud558\ub77d\uc138)</li> <li>\ud589\ub3d9: \ubc14\ub85c \ub9e4\uc218\ud558\uc9c0 \uc54a\uace0 \uad00\uc885\uc5d0 \ub123\uace0 '\uad00\ub9dd'.</li> </ul>"},{"location":"strategy/ross_cameron/#2","title":"2\ub2e8\uacc4: \ubcfc\ub9b0\uc800 \ubc34\ub4dc \uc774\ud0c8 \ubc0f \uac00\uaca9 \ubcc0\ud654 \ud655\uc778","text":"<ul> <li>\uc870\uac74: \ud558\ub77d \uc7a5\uc545\ud615 \uc74c\ubd09\uc774 \uacc4\uc18d \ub5a8\uc5b4\uc9c0\uba70, \uc8fc\uac00\uac00 \ubcfc\ub9b0\uc800 \ubc34\ub4dc \ud558\ub2e8\uc120\uc744 \ud130\uce58\ud558\uac70\ub098 \uc774\ud0c8\ud574\uc57c \ud568. (\uadf9\ub2e8\uc801 \uacf5\ud3ec \uc0c1\ud0dc \ud655\uc778)</li> </ul>"},{"location":"strategy/ross_cameron/#3-w","title":"3\ub2e8\uacc4: \ubc18\uc804 \uce94\ub4e4 \ubc0f '\uc30d\ubc14\ub2e5(W)' \ud655\uc778","text":"<ul> <li>\uc870\uac74 1: \ud558\ub77d\uc138\ub97c \uba48\ucd94\uace0 \ubc18\uaca9\ud558\ub294 '\uc7a5\uc545\ud615 \uc591\ubd09' \ub4f1\uc7a5 (\uc9c1\uc804 \uc74c\ubd09\uc758 \ubab8\ud1b5\uc744 \uac70\uc758 \ub2e4 \ub36e\ub294 \uc591\ubd09).</li> <li>\uc870\uac74 2: \uac15\ud55c \ud558\ub77d\uc138\ub294 V\uc790 \ubc18\ub4f1\uc774 \uc5b4\ub835\uae30 \ub54c\ubb38\uc5d0, \ud55c \ubc88 \ub354 \ub20c\ub838\ub2e4\uac00 \uc62c\ub77c\uac00\ub294 '\ub450 \ubc88\uc9f8 \ubc14\ub2e5(\uc30d\ubc14\ub2e5)'\uc774 \ub4f1\uc7a5\ud558\ub294\uc9c0 \uae30\ub2e4\ub9bc.</li> <li>\uc870\uac74 3 (\ud575\uc2ec): \uc774\ub54c \ud615\uc131\ub418\ub294 \ub450 \ubc88\uc9f8 \ubc14\ub2e5\uc740 \ubc18\ub4dc\uc2dc \ubcfc\ub9b0\uc800 \ubc34\ub4dc \ub0b4\ubd80(\ud558\ub2e8\uc120 \uc704\ucabd)\uc5d0\uc11c \ud615\uc131\ub418\uc5b4\uc57c \ud568.</li> </ul>"},{"location":"strategy/ross_cameron/#rsi-macd","title":"\ud83d\udd0d \ucd5c\uc885 \uac80\uc99d \ubc0f \uc9c4\uc785: RSI \ub2e4\uc774\ubc84\uc804\uc2a4 + MACD","text":"<p>\uc560\ub9e4\ud55c \uc18d\uc784\uc218\ub97c \ud544\ud130\ub9c1\ud558\uae30 \uc704\ud574 \ucd5c\uc885 \ub3c4\uc7a5\uc744 \ucc0d\uc2b5\ub2c8\ub2e4. - \uc870\uac74 (\ub2e4\uc774\ubc84\uc804\uc2a4): \uc8fc\uac00\uc758 \uc800\uc810\uc740 \ub0ae\uc544\uc84c\ub294\ub370, RSI\uc758 \uc800\uc810\uc740 \ub192\uc544\uc9c0\ub294 '\uc0c1\uc2b9 \ub2e4\uc774\ubc84\uc804\uc2a4' \ubc1c\uc0dd \ud655\uc815. (\ud558\ub77d \uc5d0\ub108\uc9c0\uac00 \uc18d\uc73c\ub85c\ub294 \uace0\uac08\ub418\uc5c8\ub2e4\ub294 \uc99d\uac70) - \uc9c4\uc785 \ud0c0\uc774\ubc0d (MACD): \ud30c\ub780\uc0c9 MACD \uc120\uc774 \ube68\uac04\uc0c9 \uc2dc\uadf8\ub110 \uc120\uc744 \ub6ab\uace0 \uc62c\ub77c\uac00\ub294 \uace8\ub4e0 \ud06c\ub85c\uc2a4\uac00 \ubc1c\uc0dd\ud560 \ub54c \uc9c4\uc785 \ud655\uc815! - \uc2e4\ud589:     - \ud0c0\uc810: \uc870\uac74\uc774 \uc644\uc131\ub41c \ub450 \ubc88\uc9f8 \uc7a5\uc545\ud615 \uc591\ubd09\uc758 \uc885\uac00.     - \uc190\uc808\uac00 (Stop Loss): \uc9c1\uc804 \uc30d\ubc14\ub2e5\uc758 \uc804\uc800\uc810(\ubcfc\ub9b0\uc800 \ubc34\ub4dc \ud558\ub2e8 \uadfc\ucc98).     - \uc775\uc808\uac00 (Take Profit): \uc190\uc775\ube44 1 : 2 \ub85c \uc138\ud305.</p>"},{"location":"strategy/ross_cameron/#_2","title":"\ud83d\udd34 \uc20f(\ub9e4\ub3c4) \ud3ec\uc9c0\uc158 \uc9c4\uc785 \uc804\ub7b5","text":"<p>\ub871 \uc804\ub7b5\uc744 \uc815\ud655\ud788 \uac70\uafb8\ub85c \ub4a4\uc9d1\uc740 \ud615\ud0dc\uc785\ub2c8\ub2e4.</p> <ol> <li>RSI \uc608\ube44 \uc2e0\ud638: RSI\uac00 70 \uc774\uc0c1(\uacfc\ub9e4\uc218)\uc73c\ub85c \uce58\uc19f\uc744 \ub54c \ud0d0\uc0c9.</li> <li>\ubcfc\ub9b0\uc800 \ubc34\ub4dc \ud655\uc778: \uac15\ud55c \uc7a5\ub300 \uc591\ubd09\uc774 \ubcfc\ub9b0\uc800 \ubc34\ub4dc \uc0c1\ub2e8\uc120\uc744 \ud130\uce58\ud558\uac70\ub098 \ubc14\uae65\uc73c\ub85c \uc774\ud0c8\ud558\uba70 \uad11\uae30\uac00 \uadf9\uc5d0 \ub2ec\ud55c \uc0c1\ud0dc \ud655\uc778.</li> <li>\uc30d\ubd09(M) \ud655\uc778: \uc7a5\uc545\ud615 \uc74c\ubd09\uc774 \ub728\uba74\uc11c \ud558\ub77d \uc2dc\uadf8\ub110 \ubc1c\uc0dd \ud6c4, \ub2e4\uc2dc \uc624\ub974\ub824 \ud558\uc9c0\ub9cc \uc774\uc804 \uace0\uc810\uc744 \ub118\uc9c0 \ubabb\ud558\ub294 \ub450 \ubc88\uc9f8 \uace0\uc810(\uc30d\ubd09)\uc774 \ub9cc\ub4e4\uc5b4\uc9d0. \uc774 \uc30d\ubd09\uc740 \ubc18\ub4dc\uc2dc \ubcfc\ub9b0\uc800 \ubc34\ub4dc \ub0b4\ubd80(\uc0c1\ub2e8\uc120 \uc544\ub798)\uc5d0 \uc788\uc5b4\uc57c \ud568.</li> <li>\ucd5c\uc885 \uac80\uc99d (\ub2e4\uc774\ubc84\uc804\uc2a4+MACD):</li> <li>\uc8fc\uac00 \uace0\uc810\uc740 \ub192\uc544\uc9c0\uac70\ub098 \ud6a1\ubcf4\ud558\ub294\ub370, RSI \uace0\uc810\uc740 \ub0ae\uc544\uc9c0\ub294 '\ud558\ub77d \ub2e4\uc774\ubc84\uc804\uc2a4' \ub69c\ub837\ud558\uac8c \uad00\ucc30.</li> <li>\ud30c\ub780\uc0c9 MACD \uc120\uc774 \ube68\uac04\uc0c9 \uc2dc\uadf8\ub110 \uc120\uc744 \ud558\ud5a5 \ub3cc\ud30c\ud558\ub294 \ub370\ub4dc \ud06c\ub85c\uc2a4 \ubc1c\uc0dd!</li> <li>\uc2e4\ud589:</li> <li>\ud0c0\uc810: \uc8fd\uc74c\uc758 \ub370\ub4dc\ud06c\ub85c\uc2a4\ub97c \ud655\uc815\uc9c0\uc740 \ud574\ub2f9 \ud558\ub77d \uc7a5\uc545 \uce94\ub4e4\uc758 \uc885\uac00.</li> <li>\uc190\uc808\uac00: \uc2dc\uadf8\ub110\uc744 \ub9cc\ub4e0 \uc9c1\uc804\uc758 \ub2e8\uae30 \ucd5c\uace0\uc810.</li> <li>\uc775\uc808\uac00: \uc190\uc775\ube44 1 : 1 \ub85c \uc138\ud305. (\ud558\ub77d\uc740 \uc0c1\uc2b9\ubcf4\ub2e4 \uae09\uaca9\ud788 \ube60\uc9c0\ubbc0\ub85c \ubcf4\uc218\uc801 \ubaa9\ud45c)</li> </ol>"},{"location":"strategy/ross_cameron/#ai-next-step","title":"\ud83e\udd16 AI \ubd07 \uc801\uc6a9 \ubc29\uc548 (Next Step)","text":"<p>\uc55e\uc73c\ub85c <code>quant_analyzer.py</code> \ubaa8\ub4c8\uc5d0\uc11c \uc704 \uc9c0\ud45c\ub4e4\uc744 \uacc4\uc0b0\ud560 \ub54c \uc544\ub798 \ub85c\uc9c1\uc744 \uc6b0\uc120 \uc21c\uc704\ub85c \uac1c\ubc1c/\uc801\uc6a9\ud574\uc57c \ud569\ub2c8\ub2e4. 1. \ub2e8\uc21c\ud788 RSI\uac00 30 \ubc11\uc774\ub77c\uace0 \"\ub9e4\uc218\" \ud14d\uc2a4\ud2b8\ub97c \ubc49\ub294 \uac83\uc774 \uc544\ub2c8\ub77c, \"\uc608\ube44 \uc2e0\ud638 \ud3ec\ucc29\" \ubb38\uad6c\ub85c \ubcc0\uacbd. 2. \ud310\ub2e4\uc2a4(Pandas)\ub97c \uc774\uc6a9\ud558\uc5ec \uc804\uc800\uc810, \uc804\uace0\uc810\uacfc RSI \uace0\uc810/\uc800\uc810\uc744 \ube44\uad50\ud558\ub294 \ub85c\uceec '\ub2e4\uc774\ubc84\uc804\uc2a4 \uacc4\uc0b0 \ub85c\uc9c1' \ucd94\uac00. 3. MACD \uace8\ub4e0/\ub370\ub4dc\ud06c\ub85c\uc2a4 \ubc1c\uc0dd \uc5ec\ubd80\ub97c True/False\ub85c \uccb4\ud06c\ud558\ub294 \ucd5c\uc885 \uc9c4\uc785 \uc54c\uace0\ub9ac\uc998 \ubcc0\uc218(Filter) \ucd94\uac00.</p>"}]}